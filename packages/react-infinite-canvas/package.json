{
  "name": "react-infinite-canvas",
  "version": "0.1.0",
  "description": "A performant infinite canvas React component powered by OffscreenCanvas and Web Workers",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "infinite-canvas",
    "canvas",
    "offscreen-canvas",
    "web-worker",
    "pan",
    "zoom"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  },
  "scripts": {
    "build": "vite build && cp src/styles.css dist/styles.css",
    "dev": "vite build --watch"
  }
}
